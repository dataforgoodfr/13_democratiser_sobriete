PUBLIC_RAG_PIPELINE=policy
PUBLIC_POLICY_PANEL_ENABLED=true
PUBLIC_POLICY_COLOR_ENABLED=true
CHAT_SUFFICIENCY_API_URL=http://localhost:8000
PUBLIC_SHOW_FULL_NAVBAR=false  # set to false for inclusion in iframe

# Auth.js / Keycloak
TOPSITE_URL=https://www.thesufficiencylab.org
AUTH_SECRET=replace-with-a-long-random-secret  # generate with openssl rand -base64 12
AUTH_TRUST_HOST=true
AUTH_KEYCLOAK_ID=replace-with-keycloak-client-id
AUTH_KEYCLOAK_SECRET=replace-with-keycloak-client-secret
AUTH_KEYCLOAK_ISSUER=replace-with-keycloak-issuer-url
# Output data files (exclude all except essential app inputs)
# Keep only the minimum required for the dashboard to run on CleverCloud.
output/**
!output/ewbi_master_aggregated.csv
!output/unified_all_levels_1_to_5.csv
!output/unified_all_levels_1_to_5_pca*.csv
!output/*.md
!output/**/*.md

# Reports: exclude project-level data and outputs
reports/*/external_data/
reports/*/output/
reports/*/outputs/

# Reports: exclude generated heavy artifacts (keep code/notebooks/markdown)
reports/**/*.png
reports/**/*.jpg
reports/**/*.jpeg
reports/**/*.svg
reports/**/*.pdf
reports/**/*.html
reports/**/*.parquet
reports/**/*.feather
reports/**/*.pkl
reports/**/*.pickle
reports/**/*.zip

# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
env/
ENV/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Jupyter notebooks
*.ipynb_checkpoints/


# Logs
*.log

# Temporary files
*.tmp
*.temp 